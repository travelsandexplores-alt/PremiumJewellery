rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: admin
    // Fields:
    //   - adminPassword: string (required) - Password for admin panel
    //   - shopName: string (optional) - Name of the shop
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //   - price: number (required)
    //   - imageUrl: string (required)
    //   - category: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - buyerId: string (required)
    //   - buyerName: string (required)
    //   - buyerEmail: string (required)
    //   - items: list (required)
    //   - totalAmount: number (required)
    //   - paymentDetails: map (optional)
    //   - status: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - name: string (required)
    //   - email: string (required)
    //   - photoURL: string (optional)
    //   - role: string (required) - 'admin' or 'user'
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "travelsandexplores@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.imageUrl is string && data.imageUrl.size() > 0 &&
             data.createdAt is timestamp;
    }

    function isValidOrder(data) {
      return data.buyerId is string &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'completed'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/admin {
      allow read: if true; // Needed to check password on login
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.buyerId == request.auth.uid);
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create, update: if isOwner(userId) && 
        (request.resource.data.role == 'user' || isAdmin());
    }
  }
}
